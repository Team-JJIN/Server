# 이 파일을 복사해서 .env로 만들고 실제 값을 채워주세요.
# .env는 절대 git에 커밋하지 마세요 (.gitignore에 이미 등록되어 있습니다)
#   cp .env.example .env

# MySQL 루트 계정 비밀번호 (컨테이너 초기화용, 앱에서는 사용하지 않음)
MYSQL_ROOT_PASSWORD=changeme_root_password

# 앱이 실제로 사용할 DB 이름 / 계정 (root 대신 별도 계정 사용 권장)
DB_NAME=jjin
DB_USERNAME=jjin_user
DB_PASSWORD=changeme_db_password

# JWT 서명에 사용할 비밀키 (32자 이상 랜덤 문자열 권장)
# 생성 예시: openssl rand -base64 32
JWT_SECRET=changeme_jwt_secret_min_32_chars

# ECR(비공개 이미지 저장소) 리포지토리 URI, 태그(:latest)는 제외
# 로컬 개발에서는 app 컨테이너를 띄우지 않으므로 비워둬도 무방, EC2 배포 시에만 필요
# 예: 123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/jjin-server
ECR_IMAGE=
